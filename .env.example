# Application Settings
PROJECT_NAME="Component Logistics Extractor API"
VERSION="1.0.0"
ENVIRONMENT="development"

# API Security (Clients must pass this in the x-api-key header)
EXTRACTOR_API_KEY="your-super-secret-local-dev-key"

# LLM Configuration
LLM_PROVIDER="gemini"
EXTRACTION_MODEL="gemini-1.5-pro"
FALLBACK_MODEL="gemini-1.5-flash"

# Provider API Keys
GEMINI_API_KEY="your_google_gemini_api_key_here"
OPENAI_API_KEY=""
